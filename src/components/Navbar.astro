---
interface Props {
  variant?: 'index' | 'product' | 'admin';
}
const { variant = 'index' } = Astro.props;
const logoHref = variant === 'index' ? '/' : '/';
---

<header class:list={['navbar', variant === 'product' && 'navbar-with-search']}>
  <a href={logoHref} class="logo-block">
    <div class="logo-icon">
      <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="40" height="40" rx="4" fill="#0a0a0a"/>
        <path d="M20 8L28 14V26L20 32L12 26V14L20 8Z" fill="url(#pin-grad)"/>
        <path d="M20 14L24 17V23L20 26L16 23V17L20 14Z" fill="#fff"/>
        <text x="20" y="22" text-anchor="middle" fill="#0a0a0a" font-size="8" font-weight="bold" font-family="sans-serif">V</text>
        <defs>
          <linearGradient id="pin-grad" x1="12" y1="8" x2="28" y2="32" gradientUnits="userSpaceOnUse">
            <stop stop-color="#2563eb"/>
            <stop offset="1" stop-color="#dc2626"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
    <div class="logo-text">
      <span class="logo-name">VARYON</span>
      <span class="logo-tagline">-SHOP-</span>
    </div>
  </a>

  <nav class="nav-links">
    <!-- Menú desplegable por categorías -->
    <div class="nav-dropdown" id="nav-menu">
      <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
        Menu
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" class="chevron">
          <path d="M7 10l5 5 5-5z"/>
        </svg>
      </button>
      <ul class="dropdown-list" id="dropdown-categories" role="menu">
        <li class="dropdown-loading">Carregando...</li>
      </ul>
    </div>

    <a href="#">Stores</a>
    <a href="#">About</a>
    <a href="/admin" class:list={['nav-admin', variant === 'admin' && 'active']}>Admin</a>
  </nav>

  <div class="header-icons">
    {variant === 'product' && (
      <div class="search-bar-inline">
        <input type="text" id="navbar-search" placeholder="Search" aria-label="Buscar" />
        <button type="button" class="search-btn-round" aria-label="Buscar">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
          </svg>
        </button>
      </div>
    )}
    <button class="icon-btn" aria-label="Usuario">
      <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
      </svg>
    </button>
  </div>
</header>

<!-- Menú dinámico: carga categorías desde la API -->
<script>
  const API = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8080';

  async function loadMenu() {
    const list = document.getElementById('dropdown-categories');
    if (!list) return;

    try {
      const [catsRes, prodsRes] = await Promise.all([
        fetch(`${API}/api/products/categories`),
        fetch(`${API}/api/products`),
      ]);

      const categories: string[] = await catsRes.json();
      const products: Array<{ id: number; name: string; category?: string }> = await prodsRes.json();

      if (categories.length === 0) {
        list.innerHTML = '<li class="dropdown-empty">Sin categorías</li>';
        return;
      }

      list.innerHTML = categories.map(cat => {
        const catProducts = products.filter(p => p.category === cat);
        const items = catProducts.map(p =>
          `<li role="menuitem"><a href="/product/${p.id}" class="dropdown-product">${p.name}</a></li>`
        ).join('');
        return `
          <li class="dropdown-category" role="none">
            <span class="cat-label">${cat}</span>
            <ul class="cat-products">${items}</ul>
          </li>`;
      }).join('');
    } catch {
      const list = document.getElementById('dropdown-categories');
      if (list) list.innerHTML = '<li class="dropdown-empty">API offline</li>';
    }
  }

  // Toggle abre/cierra
  const trigger = document.querySelector('.nav-dropdown-trigger') as HTMLButtonElement;
  const dropdown = document.getElementById('nav-menu');

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdown?.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  // Cierra al clickear fuera
  document.addEventListener('click', () => {
    dropdown?.classList.remove('open');
    trigger?.setAttribute('aria-expanded', 'false');
  });

  loadMenu();
</script>

<style>
  /* Dropdown menú */
  .nav-dropdown { position: relative; }

  .nav-dropdown-trigger {
    background: none;
    border: none;
    color: rgba(255,255,255,0.95);
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0;
    text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;
    font-family: inherit;
  }

  .nav-dropdown-trigger:hover { color: #fff; }

  .chevron {
    transition: transform 0.2s;
  }

  .nav-dropdown.open .chevron {
    transform: rotate(180deg);
  }

  .dropdown-list {
    display: none;
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 0;
    background: #1a1a2e;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    min-width: 220px;
    padding: 0.5rem 0;
    list-style: none;
    margin: 0;
    z-index: 100;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .nav-dropdown.open .dropdown-list { display: block; }

  .dropdown-loading,
  .dropdown-empty {
    padding: 0.6rem 1rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
  }

  .dropdown-category { padding: 0.4rem 0; }

  .cat-label {
    display: block;
    padding: 0.35rem 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #2563eb;
  }

  .cat-products {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .dropdown-product {
    display: block;
    padding: 0.4rem 1rem 0.4rem 1.5rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .dropdown-product:hover {
    background: rgba(37,99,235,0.2);
    color: #fff;
  }

  .dropdown-category + .dropdown-category {
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  /* Admin link */
  .nav-admin {
    font-size: 0.8rem;
    opacity: 0.7;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 4px;
    padding: 0.2rem 0.5rem !important;
  }
  .nav-admin:hover, .nav-admin.active { opacity: 1; background: rgba(255,255,255,0.1); }

  /* Search inline (variant product) */
  .navbar-with-search .header-icons {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }

  .search-bar-inline {
    display: flex;
    align-items: center;
    background: #fff;
    border: 2px solid #0a0a0a;
    border-radius: 999px;
    overflow: hidden;
  }

  .search-bar-inline input {
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    width: 140px;
    font-size: 0.9rem;
    outline: none;
    color: #0a0a0a;
  }

  .search-btn-round {
    width: 36px;
    height: 36px;
    border: none;
    background: #fff;
    color: #0a0a0a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
