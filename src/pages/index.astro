---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import ProductCard from '../components/ProductCard.astro';
import type { Product } from '../types/product';

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8080';

let products: Product[] = [];
let error = false;

try {
  const res = await fetch(`${API_URL}/api/products`);
  if (res.ok) products = await res.json();
} catch {
  error = true;
}
---

<BaseLayout title="VARYON - Shop.">
  <Navbar variant="index" />

  <div class="search-wrapper">
    <div class="search-bar">
      <input type="text" id="search-input" placeholder="Search" aria-label="Buscar" />
      <span class="search-icon">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </span>
    </div>
  </div>

  {error && (
    <p class="api-error">
      ⚠️ No foi possível conectar à API. Verifique se o backend está rodando em <code>{API_URL}</code>.
    </p>
  )}

  <section class="products-section">
    <div class="product-grid" id="product-grid">
      {products.map(p => (
        <ProductCard product={p} linkTo={`/product/${p.id}`} />
      ))}
      {products.length === 0 && !error && (
        <p class="no-results">Nenhum produto encontrado.</p>
      )}
    </div>
  </section>
</BaseLayout>

<!-- Búsqueda client-side: filtra los cards ya renderizados en el DOM -->
<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const grid = document.getElementById('product-grid');

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    grid?.querySelectorAll<HTMLElement>('.product-card').forEach(card => {
      const text = card.textContent?.toLowerCase() ?? '';
      card.style.display = !q || text.includes(q) ? '' : 'none';
    });
  });
</script>

<style>
  .search-wrapper {
    display: flex;
    justify-content: center;
    padding: 1.5rem 2rem;
  }

  .search-bar {
    position: relative;
    width: 100%;
    max-width: 560px;
    display: flex;
    align-items: center;
  }

  .search-bar input {
    width: 100%;
    padding: 0.85rem 3rem 0.85rem 1.25rem;
    border: 2px solid #0a0a0a;
    border-radius: 999px;
    background: #fff;
    color: #0a0a0a;
    font-size: 1rem;
    outline: none;
  }

  .search-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #0a0a0a;
    pointer-events: none;
  }

  .products-section { padding: 0 2rem 3rem; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .no-results {
    grid-column: 1 / -1;
    text-align: center;
    color: #555;
    padding: 2rem;
  }

  .api-error {
    text-align: center;
    background: #fef3c7;
    color: #92400e;
    padding: 0.75rem 1.5rem;
    margin: 0 1rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .search-wrapper { padding: 1rem; }
    .products-section { padding: 0 1rem 2rem; }
  }
</style>
